# OpenRouter is optional: without a key, the application returns clearly-labelled mock analysis.
OPENROUTER_API_KEY=# You Can Put Your OpenRouter API Key Here
OPENROUTER_MODEL=openai/gpt-4o-mini

# Comma-separated browser origins permitted to call the API.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080,http://127.0.0.1:3000,http://127.0.0.1:5173,http://127.0.0.1:8080
MAX_UPLOAD_SIZE_BYTES=52428800
MAX_ANALYSIS_CHARS=200000
OPENROUTER_TIMEOUT_SECONDS=90
